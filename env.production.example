# 프로덕션 환경변수 - Railway에 그대로 복붙
# Railway 대시보드 → Variables 탭에 입력

DATABASE_URL=postgresql://유저:비밀번호@호스트:5432/DB이름
GEMINI_API_KEY=your_gemini_api_key_here
OPEN_ASSEMBLY_API_KEY=your_api_key_here
PORT=3000
ALLOWED_ORIGIN=https://your-domain.railway.app

# 세션 보안 (랜덤 문자열 생성: openssl rand -base64 32)
SESSION_SECRET=your_random_secret_here
NODE_ENV=production
